generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CategoryType {
  INCOME
  EXPENSE
}

model Category {
  id        String       @id @default(cuid())
  name      String
  type      CategoryType
  color     String
  createdAt DateTime     @default(now())
  items     Item[]
  entries   MonthlyEntry[]
}

model Item {
  id         String         @id @default(cuid())
  name       String
  category   Category       @relation(fields: [categoryId], references: [id])
  categoryId String
  dueDay     Int?
  // Frequência da recorrência em meses (1=mensal, 2=bimestral, 3=trimestral…):
  // o provisionamento e o "Copiar mês anterior" respeitam a cadência.
  intervalMonths Int  @default(1)
  // Regra de data por dia útil (ex.: 5 = 5º dia útil): a data varia por mês;
  // quando setado, dueDay é ignorado e purchaseDate é calculada por mês.
  businessDay   Int?
  // Mês (1-12) em que a conta RENOVA/vence anualmente (seguro, anuidade…):
  // gera alertas no Dashboard, na tela do Mês e no Telegram.
  renewalMonth  Int?
  // Reajuste anual: no mês adjustMonth (1-12), o valor sobe adjustPercent %
  // OU adjustAmount reais (um dos dois), composto a cada aniversário.
  adjustMonth   Int?
  adjustPercent Decimal? @db.Decimal(5, 2)
  adjustAmount  Decimal? @db.Decimal(12, 2)
  active     Boolean        @default(true)
  notes      String?
  createdAt  DateTime       @default(now())
  entries    MonthlyEntry[]
  subscription CardSubscription?

  @@index([categoryId])
}

model CreditCard {
  id        String         @id @default(cuid())
  name      String
  color     String
  // Dia de fechamento da fatura (1-31). Compra APÓS o fechamento cai na
  // fatura do mês seguinte — usado pela importação de CSV para rotear cada
  // compra pela data. null = importar tudo no primeiro mês em aberto.
  closingDay Int?
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())
  entries   MonthlyEntry[]
  transactions CardTransaction[]
  subscriptions CardSubscription[]
}

// Assinatura cobrada no cartão (YouTube, Spotify…): provisionada como LINHA
// PRÓPRIA no mês (Item recorrente, fora do consolidado do cartão), com
// duração escolhida. Quando a cobrança real chega na fatura (CSV/share), a
// linha do mês é CONSUMIDA: marcada como paga e zerada — o valor passa a
// viver dentro do consolidado do cartão, sem contar em dobro.
model CardSubscription {
  id          String     @id @default(cuid())
  card        CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  cardId      String
  // Item recorrente que carrega as linhas provisionadas no /mes.
  item        Item?      @relation(fields: [itemId], references: [id], onDelete: SetNull)
  itemId      String?    @unique
  description String
  amount      Decimal    @db.Decimal(12, 2)
  // Dia do mês em que a cobrança acontece (1-31).
  chargeDay   Int
  // Duração em meses da provisão (assinaturas que vão acabar duram menos).
  months      Int        @default(12)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  transactions CardTransaction[]
}

// Extrato do cartão: cada compra/estorno individual que compõe o lançamento
// consolidado do mês (MonthlyEntry com cardId). Parcelas geram 1 registro por
// mês (seq/count). Valor negativo = estorno.
model CardTransaction {
  id               String     @id @default(cuid())
  card             CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  cardId           String
  month            DateTime   @db.Date
  description      String
  amount           Decimal    @db.Decimal(12, 2)
  purchaseDate     DateTime?  @db.Date
  installmentSeq   Int?
  installmentCount Int?
  // Pagamento antecipado da fatura (valor negativo, lançado manualmente):
  // preservado quando o CSV substitui o mês (no CSV ele vira "Pagamento
  // recebido", que é ignorado — sem a flag o reimport apagaria o abatimento).
  prepayment       Boolean    @default(false)
  // Provisão de assinatura (aponta para o cadastro): substituída pela
  // cobrança real quando ela chega (CSV substitui o mês; share troca a
  // provisão de descrição correspondente).
  subscription     CardSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subscriptionId   String?
  createdAt        DateTime   @default(now())

  @@index([cardId, month])
}

model MonthlyEntry {
  id               String      @id @default(cuid())
  item             Item?       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId           String?
  description      String?
  // Data do lançamento (avulsos sem cartão; cartão usa a data só para rotear a fatura).
  purchaseDate     DateTime?   @db.Date
  category         Category?   @relation(fields: [categoryId], references: [id])
  categoryId       String?
  card             CreditCard? @relation(fields: [cardId], references: [id], onDelete: SetNull)
  cardId           String?
  installmentId    String?
  installmentSeq   Int?
  installmentCount Int?
  month            DateTime    @db.Date
  plannedAmount    Decimal     @db.Decimal(12, 2)
  paid             Boolean     @default(false)
  paidAmount       Decimal?    @db.Decimal(12, 2)
  paidDate         DateTime?   @db.Date

  @@unique([itemId, month])
  @@index([month])
  @@index([categoryId])
  @@index([cardId])
  @@index([installmentId])
}

model ReserveBox {
  id        String   @id @default(cuid())
  name      String
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
}

// ============ INVESTIMENTOS (v1: Ações B3 + Dividendos) ============

// Posição na carteira: cotas + preço médio; cotação cacheada via brapi.dev.
model InvestmentAsset {
  id        String     @id @default(cuid())
  ticker    String     @unique // "BBSE3"
  name      String? // nome da empresa (vem da brapi)
  segment   String? // "SEGUROS" (organização do usuário)
  class     String     @default("STOCK") // v2: FII, CRYPTO…
  quantity  Int        @default(0)
  avgPrice  Decimal    @default(0) @db.Decimal(12, 4)
  lastPrice Decimal?   @db.Decimal(12, 4)
  priceAt   DateTime?
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  dividends Dividend[]
  transactions InvestmentTransaction[]
}

// Negócio importado do relatório de Negociação da B3 (compra/venda).
// hash único = dedup: reimportar o mesmo relatório não duplica nem
// reaplica o efeito em cotas/PM.
model InvestmentTransaction {
  id        String          @id @default(cuid())
  asset     InvestmentAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assetId   String
  date      DateTime        @db.Date
  side      String // BUY | SELL
  quantity  Int
  price     Decimal         @db.Decimal(12, 4)
  value     Decimal         @db.Decimal(12, 2)
  hash      String          @unique
  createdAt DateTime        @default(now())

  @@index([assetId, date])
}

// Evento de provento (dividendo/JSCP): agenda + recebimento. Ao marcar
// recebido vira um MonthlyEntry (categoria Dividendos, INCOME) — entryId
// evita duplicar.
model Dividend {
  id        String          @id @default(cuid())
  asset     InvestmentAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assetId   String
  type      String // "Dividendos" | "JSCP" | "Rendimento"
  exDate    DateTime?       @db.Date
  payDate   DateTime        @db.Date
  quantity  Int
  unitValue Decimal         @db.Decimal(12, 6)
  gross     Decimal         @db.Decimal(12, 2)
  net       Decimal         @db.Decimal(12, 2)
  received  Boolean         @default(false)
  entryId   String?
  createdAt DateTime        @default(now())

  @@index([assetId, payDate])
  @@index([received, payDate])
}
